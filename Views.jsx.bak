const SettingsView = ({ setAppState, setView: setView2, settings, setSettings, stats, saveGame }) => {
  const [activeTab, setActiveTab] = useState("audio");
  const resetGame = () => {
    if (confirm("Are you sure? This will wipe ALL progress! This cannot be undone.")) {
      localStorage.clear();
      window.location.reload();
    }
  };
  const exportSave = () => {
